# examples/.gitlab-ci.yml.example
# ==============================================================================
# GitLab CI Pipeline Example for Helm Monorepo Optimization
#
# SEC-M1 FIX: Updated to use SSH deploy key pattern (matches main .gitlab-ci.yml)
# PY-L4 FIX: Updated Python image to 3.11-slim
# ==============================================================================

stages:
  - build
  - test
  - sync-secrets
  - deploy-orchestration

variables:
  # Standard GitLab CI variables
  DOCKER_IMAGE: $CI_REGISTRY_IMAGE/$CI_PROJECT_NAME
  IMAGE_TAG: $CI_PIPELINE_ID
  # Vault configurations
  VAULT_ADDR: "https://vault.example.com"
  VAULT_AUTH_ROLE: "gitlab-ci-role"

.base-job:
  image: python:3.11-slim
  before_script:
    - apt-get update && apt-get install -y git jq curl ssh-client
    - pip install -r scripts/requirements.txt
    # Install Helm (pinned version)
    - curl -fsSL https://get.helm.sh/helm-v3.15.0-linux-amd64.tar.gz | tar xz -C /usr/local/bin --strip-components=1 linux-amd64/helm
    # Set up Git for pushback via SSH deploy key
    - git config --global user.name "GitLab CI Bot"
    - git config --global user.email "ci-bot@example.com"
    - mkdir -p ~/.ssh && chmod 700 ~/.ssh
    - echo "$CI_SSH_DEPLOY_KEY" | tr -d '\r' | ssh-add - 2>/dev/null || true
    - ssh-keyscan "${CI_SERVER_HOST}" >> ~/.ssh/known_hosts 2>/dev/null || true
    - |
      if ssh-add -l > /dev/null 2>&1; then
        git remote set-url origin "git@${CI_SERVER_HOST}:${CI_PROJECT_PATH}.git"
      else
        echo "FATAL: CI_SSH_DEPLOY_KEY is not configured."
        exit 1
      fi

# 1. Build and Push
build-image:
  stage: build
  image: docker:24.0
  services:
    - docker:24.0-dind
  script:
    - docker build -t ${DOCKER_IMAGE}:${IMAGE_TAG} .
    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY
    - docker push ${DOCKER_IMAGE}:${IMAGE_TAG}
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'

# 2. Run Tests
run-tests:
  stage: test
  image: python:3.11-slim
  before_script:
    - pip install -r scripts/requirements.txt
  script:
    - python -m pytest scripts/test_generator.py -v --tb=short
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
      changes:
        - scripts/**/*
        - projects/**/*.yaml
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'

# 3. Sync Secrets from Vault
sync-secrets:
  stage: sync-secrets
  extends: .base-job
  script:
    - chmod +x scripts/vault_sync.sh
    - ./scripts/vault_sync.sh "secret/data/team/ecommerce/dev" "ecommerce-secret" "ecommerce"
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'

# 4. Generate Charts and Push Back to Git
orchestrate-deploy:
  stage: deploy-orchestration
  extends: .base-job
  needs:
    - job: run-tests
      optional: true
  resource_group: git-push-lock
  script:
    - chmod +x scripts/deploy.sh
    - ./scripts/deploy.sh --project ecommerce --env dev --image-tag ${IMAGE_TAG}
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
